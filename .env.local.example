# AWS Bedrock — required for "The Briefing"
# Uses BRIEFING_ prefix to avoid collision with shell env vars
BRIEFING_AWS_REGION=us-east-1
BRIEFING_AWS_ACCESS_KEY_ID=
BRIEFING_AWS_SECRET_ACCESS_KEY=
BRIEFING_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Optional: Tavily search for Phase 2 company enrichment
# Free tier at tavily.com — 1000 searches/month
TAVILY_API_KEY=

# Optional: Redis for persistent briefing log
# Accepts any redis:// connection string (Vercel KV, Upstash, Redis Labs, etc.)
REDIS_URL=

# Secret for reading the briefing log via GET /api/briefing/log
LOG_SECRET=
